# Frontend environment variables
# In development: leave empty to use Vite proxy (/api -> backend on :3001).
# In production: set this to the public backend URL, for example https://api.example.com
VITE_API_BASE_URL=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Set to true to run fully local with deterministic dummy data (no API calls).
# Accepted truthy values: true, 1, yes, on
VITE_USE_MOCK_DATA=false
